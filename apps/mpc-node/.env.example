# Per-node config for apps/mpc-node.
#
# Copy this to .env and adjust for each instance.

# 'p1' or 'p2' — must match the share file's role.
MPC_ROLE=p1

# Path to the share file produced by `pnpm dkg`.
MPC_SHARE_PATH=./shares/share-p1.json

# HTTP port. Coordinator addresses each node by URL, so the port can be
# anything; the docker-compose uses 8001 for p1 and 8002 for p2.
PORT=8001
